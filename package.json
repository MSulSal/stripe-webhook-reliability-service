{
  "name": "stripe-webhook-reliability-service",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Stripe webhook reliability service with idempotency, persistence, and replay-safe retries.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit --coverage=false",
    "test:integration": "vitest run tests/integration --coverage=false",
    "replay": "tsx src/scripts/replayFailedEvent.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "stripe": "^18.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.17.24",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^8.57.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
